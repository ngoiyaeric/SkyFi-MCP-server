# SkyFi MCP Server Configuration Template
# Copy this file to .env and configure with your actual values

# ====================================
# CORE SERVER CONFIGURATION
# ====================================

# MCP Transport Configuration
# Options: stdio, streamable-http, sse
TRANSPORT=stdio
PORT=8000

# Server Mode Configuration
READ_ONLY_MODE=false
ENABLED_TOOLS=

# Debug and Development
DEBUG=false
LOG_LEVEL=INFO

# ====================================
# SKYFI PLATFORM API CONFIGURATION
# ====================================

# Required: SkyFi Platform API endpoint
SKYFI_URL=https://app.skyfi.com/platform-api/pricing

# Authentication Method 1: API Key (Current Standard)
# Get your API key from: https://app.skyfi.com/platform/settings/api-keys
SKYFI_API_KEY=your_email@domain.com:your_api_key_here

# Authentication Method 2: Personal Access Token (Future)
# For enhanced security and user-specific access
# SKYFI_PERSONAL_TOKEN=your_personal_access_token

# Authentication Method 3: OAuth 2.0 (Enterprise)
# For organization-level integrations
# SKYFI_OAUTH_CLIENT_ID=your_oauth_client_id
# SKYFI_OAUTH_CLIENT_SECRET=your_oauth_client_secret
# SKYFI_OAUTH_ACCESS_TOKEN=your_oauth_access_token
# SKYFI_OAUTH_REFRESH_TOKEN=your_oauth_refresh_token
# SKYFI_OAUTH_SCOPE=archive:read,order:create,delivery:configure

# Network Configuration
SKYFI_SSL_VERIFY=true
SKYFI_TIMEOUT=30
SKYFI_MAX_RETRIES=3

# Feature Configuration
SKYFI_ENABLE_ORDERING=true
SKYFI_ENABLE_WEBHOOKS=true
SKYFI_ENABLE_OPEN_DATA=true

# Budget and Rate Limiting
SKYFI_RATE_LIMIT=100
SKYFI_BUDGET_WARNING_THRESHOLD=0.8

# ====================================
# OPENSTREETMAP (NOMINATIM) CONFIGURATION
# ====================================

# OSM Nominatim API endpoint (leave default unless using custom instance)
OSM_URL=https://nominatim.openstreetmap.org

# User-Agent for OSM requests (required by OSM usage policy)
OSM_USER_AGENT=MCP-SkyFi/1.0 (your-email@domain.com)

# Rate limiting for OSM (recommended: max 1 request per second)
OSM_RATE_LIMIT=1
OSM_TIMEOUT=10
OSM_MAX_RETRIES=2

# Custom headers for enterprise OSM instances
# OSM_CUSTOM_HEADERS=X-API-Key=your_key,X-Custom-Header=value

# ====================================
# WEATHER DATA CONFIGURATION
# ====================================

# Weather API Configuration (OpenWeatherMap example)
WEATHER_URL=https://api.openweathermap.org/data/2.5
WEATHER_API_KEY=your_openweathermap_api_key_here

# Alternative weather providers
# WEATHER_PROVIDER=openweathermap  # Options: openweathermap, weatherapi, custom
# WEATHER_UNITS=metric  # Options: metric, imperial, kelvin

# Network Configuration
WEATHER_TIMEOUT=15
WEATHER_MAX_RETRIES=3
WEATHER_RATE_LIMIT=1000

# ====================================
# AUTHENTICATION & SECURITY
# ====================================

# Multi-method Authentication Precedence
# 1. Per-request headers (highest priority)
# 2. OAuth 2.0 tokens
# 3. Personal Access Tokens  
# 4. API Keys
# 5. Basic authentication (lowest priority)

# Session Configuration
SESSION_SECRET_KEY=your_super_secret_session_key_here_change_this
SESSION_TIMEOUT=3600

# JWT Configuration (for session management)
JWT_SECRET_KEY=your_jwt_secret_key_here_change_this
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Rate Limiting
GLOBAL_RATE_LIMIT=1000
PER_USER_RATE_LIMIT=100
RATE_LIMIT_WINDOW=3600

# CORS Configuration (for HTTP transport)
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# ====================================
# CACHING & PERFORMANCE
# ====================================

# Authentication Cache (seconds)
AUTH_CACHE_TTL=300
CONFIG_CACHE_TTL=3600

# Response Cache Configuration
ENABLE_RESPONSE_CACHE=false
RESPONSE_CACHE_TTL=60
RESPONSE_CACHE_MAX_SIZE=1000

# Redis Cache (optional)
# REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=your_redis_password
# REDIS_SSL=false

# Connection Pooling
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_KEEPALIVE=20
HTTP_KEEPALIVE_EXPIRY=30

# ====================================
# MONITORING & OBSERVABILITY
# ====================================

# Structured Logging
LOG_FORMAT=json
LOG_FILE=logs/mcp-skyfi.log
LOG_ROTATION=daily
LOG_RETENTION=30

# Metrics and Monitoring
ENABLE_METRICS=false
METRICS_PORT=9090

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=mcp-skyfi
# OTEL_RESOURCE_ATTRIBUTES=service.version=0.1.0

# ====================================
# DEVELOPMENT & TESTING
# ====================================

# Development Mode
DEV_MODE=false
DEV_AUTO_RELOAD=false

# Testing Configuration
TEST_MODE=false
TEST_MOCK_EXTERNAL_APIS=true
TEST_FIXTURES_PATH=tests/fixtures

# Mock API Responses (for development)
MOCK_SKYFI_API=false
MOCK_OSM_API=false
MOCK_WEATHER_API=false

# ====================================
# DOCKER & DEPLOYMENT
# ====================================

# Container Configuration
CONTAINER_USER=app
CONTAINER_WORKDIR=/home/app

# Health Check Configuration
HEALTHCHECK_INTERVAL=30
HEALTHCHECK_TIMEOUT=10
HEALTHCHECK_RETRIES=3

# Kubernetes Configuration
K8S_NAMESPACE=default
K8S_SERVICE_ACCOUNT=mcp-skyfi

# ====================================
# ADVANCED CONFIGURATION
# ====================================

# Custom Headers for Enterprise Deployments
# CUSTOM_HEADERS=X-Organization=your-org,X-Environment=production

# Proxy Configuration
# HTTP_PROXY=http://proxy.company.com:8080
# HTTPS_PROXY=http://proxy.company.com:8080
# NO_PROXY=localhost,127.0.0.1,.company.com

# Database Configuration (for future features)
# DATABASE_URL=postgresql://user:password@localhost/mcp_skyfi
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20

# Advanced Feature Flags
FEATURE_EXPERIMENTAL_TOOLS=false
FEATURE_BETA_APIS=false
FEATURE_ADMIN_ENDPOINTS=false

# Multi-tenant Configuration (Enterprise)
MULTI_TENANT_MODE=false
DEFAULT_ORGANIZATION=default
ORGANIZATION_HEADER=X-Organization-ID